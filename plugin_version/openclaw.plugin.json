{
  "id": "meeting-scheduler",
  "name": "Meeting Scheduler (Unified)",
  "version": "0.3.0",
  "description": "Multi-platform meeting scheduler — auto-routes by IM platform (Feishu, Slack, etc.)",
  "main": "dist/index.js",
  "engines": { "openclaw": ">=0.5.0" },
  "configSchema": {
    "LARK_APP_ID":          { "type": "string", "required": false, "description": "Feishu app id — set to enable Feishu backend" },
    "LARK_APP_SECRET":      { "type": "string", "required": false, "secret": true },
    "LARK_CALENDAR_ID":     { "type": "string", "required": false },

    "SLACK_BOT_TOKEN":      { "type": "string", "required": false, "secret": true, "description": "Slack Bot Token — set to enable Slack backend" },

    "DEFAULT_TIMEZONE":     { "type": "string", "required": false, "default": "Asia/Shanghai" },
    "WORK_HOURS":           { "type": "string", "required": false, "default": "09:00-18:00" },
    "LUNCH_BREAK":          { "type": "string", "required": false, "default": "12:00-13:30" },
    "BUFFER_MINUTES":       { "type": "number", "required": false, "default": 15 }
  }
}
